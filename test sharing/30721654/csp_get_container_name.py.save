    rc, out = run([CSPTEST, "-keys", "-enum_cont", "-fqcn", "-verifyc"])
    # строки вида \\.\HDIMAGE\...
    return re.findall(r'\\\\\.\\HDIMAGE\\[^\r\n]+', out)

def extract_name_from_name_key(name_key: Path) -> str | None:
    data = name_key.read_bytes()
    candidates = []

    # utf-16le
    try:
        s = data.decode("utf-16le", errors="ignore")
        candidates += re.findall(r"[A-Za-z0-9_\- .()\[\]А-Яа-яЁё]{4,}", s)
    except Exception:
        pass

    # cp1251
    try:
        s = data.decode("cp1251", errors="ignore")
        candidates += re.findall(r"[A-Za-z0-9_\- .()\[\]А-Яа-яЁё]{4,}", s)
    except Exception:
        pass

    # utf-8
    try:
        s = data.decode("utf-8", errors="ignore")
        candidates += re.findall(r"[A-Za-z0-9_\- .()\[\]А-Яа-яЁё]{4,}", s)
    except Exception:
        pass

    if not candidates:
        return None

    # берем самый длинный осмысленный фрагмент
    candidates.sort(key=len, reverse=True)
    return candidates[0].strip()

def main():
    ap = argparse.ArgumentParser(description="Определение имени контейнера по name.key и списку CSP")
    ap.add_argument("-d", "--dir", required=True, help="Каталог контейнера (где лежит name.key)")
    args = ap.parse_args()

    cont_dir = Path(args.dir).expanduser().resolve()
    name_key = cont_dir / "name.key"
    if not name_key.is_file():
        print(f"ERROR: Не найден name.key: {name_key}", file=sys.stderr)
        sys.exit(1)

    guess = extract_name_from_name_key(name_key)
    containers = list_containers()

    print("Список контейнеров (csptest):")
    for c in containers:
        print(" ", c)

    if guess:
        print(f"\nИмя из name.key (угадывание): {guess}")
        # пробуем сопоставить по окончанию FQCN
        match = None
        for c in containers:
            tail = c.split("\\HDIMAGE\\")[-1]
            if guess in tail:
                match = c
                break
        if not match:
            # ещё попытка: убрать слово 'копия' и сравнить
            base = guess.replace("копия", "").strip()
            for c in containers:
                tail = c.split("\\HDIMAGE\\")[-1]
                if base and base in tail:
                    match = c
                    break
        if match:
            print(f"\nТочный FQCN контейнера: {match}")
            sys.exit(0)
        else:
            print("\nНе удалось однозначно сопоставить с существующими FQCN.")
            sys.exit(2)
    else:
        print("\nНе удалось извлечь имя из name.key.")
        sys.exit(3)

